{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node ./scripts/team-safety-policy.js beforeShellExecution",
        "failClosed": true
      }
    ],
    "preToolUse": [
      {
        "command": "node ./scripts/team-safety-policy.js preToolUse",
        "matcher": "Write|StrReplace|Delete|ApplyPatch|MultiEdit|EditNotebook",
        "failClosed": true
      }
    ]
  }
}
