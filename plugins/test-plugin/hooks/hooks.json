{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node ./scripts/team-safety-policy.js beforeShellExecution",
        "failClosed": true
      }
    ],
    "beforeReadFile": [
      {
        "command": "node ./scripts/team-safety-policy.js beforeReadFile",
        "failClosed": false
      }
    ],
    "preToolUse": [
      {
        "command": "node ./scripts/team-safety-policy.js preToolUse",
        "failClosed": true
      }
    ]
  }
}
